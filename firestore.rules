rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. USERS
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /progress/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /quiz_results/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /answered_questions/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /completions/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // 2. SYLLABUS (Read-only for clients; seed via admin SDK or Firebase console)
    match /syllabus/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 3. QUIZZES (Read-only for clients; generated content stored by Cloud Functions or admin)
    match /quizzes/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 4. SQUADS (members-only write)
    match /squads/{squadId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && request.auth.uid in resource.data.memberIds;

      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update, delete: if false;
      }
      match /activity_log/{activityId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update, delete: if false;
      }
    }

    // 5. DUELS (Feature removed — rules cleaned up)
    // match /duels/{duelId} { ... } — removed

    // 6. DAILY OPERATIONS
    match /daily_operations/{dateKey} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 7. DAILY SCORES
    match /daily_scores/{dateKey} {
      allow read: if request.auth != null;
      allow write: if false;

      match /scores/{uid} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // 8. GLOBAL QUESTION BANK (Client harvester writes AI-generated questions)
    match /global_question_bank/{questionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // 9. NEWS (legacy)
    match /news/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 10. DAILY BRIEF (Read-only — ingestion handled server-side or by admin)
    match /daily_brief/{briefId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // 11. APP CONFIG (Force update service reads minimum version)
    match /app_config/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 12. SYSTEM CONFIG (Guardrail service reads rate-limit config)
    match /system/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 13. SYLLABUS QUEUE (Locked down — harvester disabled)
    match /syllabus_queue/{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

  }
}
